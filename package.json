{
  "name": "pdlc-test",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace=@pdlc-test/frontend",
    "dev:backend": "npm run dev --workspace=@pdlc-test/backend",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:frontend": "npm run test --workspace=@pdlc-test/frontend",
    "test:backend": "npm run test --workspace=@pdlc-test/backend"
  }
}
